# ═══════════════════════════════════════════════════════════════════════════════
# Configuration Production IvoireStore Server
# ═══════════════════════════════════════════════════════════════════════════════
# Copiez ce fichier en .env et remplacez les valeurs par les vôtres

# ─── Serveur ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Base de Données MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?appName=cluster

# ─── Authentification JWT ─────────────────────────────────────────────────────
# ⚠️ IMPORTANT: Changez cette valeur en production! Utiliser une clé aléatoire longue
JWT_SECRET=changez_cette_valeur_super_secrete_min_32_caracteres
JWT_EXPIRE=7d

# ─── Frontend URL (IMPORTANT POUR LES EMAILS) ─────────────────────────────────
# 🔗 Définissez l'URL complète du frontend en production
# Exemples:
#   - Vercel: https://ivoirestore.vercel.app
#   - Netlify: https://ivoirestore.netlify.app
#   - Custom domain: https://ivoirestore.ci
FRONTEND_URL=https://votre-frontend-url.com

# ─── CORS - Origines Autorisées ───────────────────────────────────────────────
# 🔐 Incluez uniquement les domaines de confiance
ALLOWED_ORIGINS=https://votre-frontend-url.com,https://admin.votre-frontend-url.com

# ─── Cloudinary (Image/Vidéo Upload) ──────────────────────────────────────────
# 📸 Obtenez vos clés sur https://cloudinary.com
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# ─── Email Configuration Gmail ─────────────────────────────────────────────────
# 📧 Utilisez un compte Gmail dédié pour la production
# 🔑 EMAIL_PASSWORD doit être un "App Password" Gmail de 16 caractères
#    Générez-le sur: https://myaccount.google.com/apppasswords
EMAIL_USER=ivoirestore@example.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# ═══════════════════════════════════════════════════════════════════════════════
# Configuration des Services de Déploiement
# ═══════════════════════════════════════════════════════════════════════════════

# Pour Render (https://render.com) - Backend hébergement recommandé
# 1. Créez un Web Service sur Render
# 2. Connectez le repo GitHub
# 3. Définissez les variables d'environnement ci-dessus
# 4. Déploiement automatique à chaque push sur main/production

# Pour Vercel (https://vercel.com) - Frontend hébergement recommandé
# 1. Importer le dossier /client
# 2. Ajouter VITE_API_URL=https://your-backend-url.onrender.com
# 3. Déploiement automatique à chaque push
